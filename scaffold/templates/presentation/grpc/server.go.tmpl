package grpc

import (
	"context"
	"fmt"
	"net"

	grpclib "google.golang.org/grpc"
	"github.com/tlmanz/catalyst/v3/infra"
)

// Config holds configuration for the gRPC server.
type Config struct {
	Port int
}

// Server is the gRPC server.
type Server struct {
	cfg Config
	ctr *infra.Container
	srv *grpclib.Server
}

// NewServer returns a new gRPC server instance.
func NewServer(cfg Config, ctr *infra.Container) (*Server, error) {
	return &Server{cfg: cfg, ctr: ctr}, nil
}

// Start starts the gRPC server.
func (s *Server) Start() error {
	lis, err := net.Listen("tcp", fmt.Sprintf(":%d", s.cfg.Port))
	if err != nil {
		return fmt.Errorf("grpc: failed to listen on port %d: %w", s.cfg.Port, err)
	}

	s.srv = grpclib.NewServer()
	RegisterAccountServiceServer(s.srv, newAccountService(s.ctr))

	go func() {
		if err := s.srv.Serve(lis); err != nil {
			s.ctr.Logger.Error(context.Background(),
				fmt.Errorf("grpc: server error: %w", err).Error())
		}
	}()

	return nil
}

// Name returns the server name.
func (s *Server) Name() string { return "gRPC" }

// Stop gracefully stops the gRPC server.
func (s *Server) Stop() error {
	s.srv.GracefulStop()
	return nil
}
