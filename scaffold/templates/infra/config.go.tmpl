package infra

import (
	"github.com/kosatnkn/catalyst-pkgs/persistence/postgres"
	"github.com/kosatnkn/catalyst-pkgs/telemetry/log/loggerjson"
)

// Config is the master config struct that holds all other config structs.
type Config struct {
	App      AppConfig         `mapstructure:"app"`
	Rest     RESTConfig        `mapstructure:"rest"`
	GraphQL  GraphQLConfig     `mapstructure:"graphql"`
	GRPC     GRPCConfig        `mapstructure:"grpc"`
	WS       WSConfig          `mapstructure:"ws"`
	Metrics  MetricsConfig     `mapstructure:"metrics"`
	Log      loggerjson.Config `mapstructure:"log"`
	Database DatabaseConfig    `mapstructure:"db"`
}

// DatabaseConfig holds shared connection settings plus separate credentials for each role.
type DatabaseConfig struct {
	Host       string              `mapstructure:"host"`
	Port       int                 `mapstructure:"port"`
	Database   string              `mapstructure:"database"`
	Schema     string              `mapstructure:"schema"`
	PoolSize   int                 `mapstructure:"poolsize"`
	Check      bool                `mapstructure:"check"`
	Runtime    DatabaseCredentials `mapstructure:"runtime"`
	Migrations MigrationConfig     `mapstructure:"migrations"`
}

// DatabaseCredentials holds the username and password for a database role.
type DatabaseCredentials struct {
	User     string `mapstructure:"user"`
	Password string `mapstructure:"password"`
}

// MigrationConfig holds the settings the embedded migrator uses at startup.
//
// Credentials is squashed, so its user/password keys sit directly under the
// `migrations` block. Schema and Table control where goose keeps its
// version-tracking table — when several services share one database, give
// each a unique Table so their migration version numbers do not collide, and
// use a dedicated Schema to keep the tracking tables out of the application
// schema. Both default to the migrator's built-in values when left empty.
type MigrationConfig struct {
	Credentials DatabaseCredentials `mapstructure:",squash"`
	Schema      string              `mapstructure:"schema"`
	Table       string              `mapstructure:"table"`
}

// RuntimeConfig returns a Postgres adapter config using the runtime (restricted) credentials.
// Use this when creating the database adapter in the container.
func (c DatabaseConfig) RuntimeConfig() postgres.Config {
	return postgres.Config{
		Host:     c.Host,
		Port:     c.Port,
		Database: c.Database,
		User:     c.Runtime.User,
		Password: c.Runtime.Password,
		PoolSize: c.PoolSize,
		Check:    c.Check,
	}
}

// AppConfig holds application configurations.
type AppConfig struct {
	Name     string `mapstructure:"name"`
	Mode     string `mapstructure:"mode"`
	Timezone string `mapstructure:"timezone"`
}

// GraphQLConfig holds GraphQL server configuration.
type GraphQLConfig struct {
	Enabled bool   `mapstructure:"enabled"`
	Port    int    `mapstructure:"port"`
	Wait    string `mapstructure:"wait"`
}

// GRPCConfig holds gRPC server configuration.
type GRPCConfig struct {
	Enabled bool `mapstructure:"enabled"`
	Port    int  `mapstructure:"port"`
}

// WSConfig holds WebSocket server configuration.
type WSConfig struct {
	Enabled bool   `mapstructure:"enabled"`
	Port    int    `mapstructure:"port"`
	Wait    string `mapstructure:"wait"`
}

// MetricsConfig holds metrics server configuration.
type MetricsConfig struct {
	Enabled bool `mapstructure:"enabled"`
	Port    int  `mapstructure:"port"`
}

// RESTConfig holds REST server configuration.
type RESTConfig struct {
	Enabled bool   `mapstructure:"enabled"`
	Port    int    `mapstructure:"port" validate:"min=80,max=65535"`
	Wait    string `mapstructure:"wait"`
	Release bool   `mapstructure:"release"`
}
